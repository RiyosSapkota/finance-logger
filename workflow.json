        "query": "SELECT category, SUM(amount) as total \nFROM expenses \nWHERE DATE_TRUNC('month', created_at) = DATE_TRUNC('month', CURRENT_DATE)\nAND chat_id = {{ $('Telegram Trigger').item.json.message.chat.id }}\nGROUP BY category \nORDER BY total DESC",

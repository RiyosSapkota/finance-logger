    {
      "parameters": {
        "jsCode": "const weekly_total = $input.item.json.weekly_total || 0;\nconst limit = 100;\nconst pre_alert = 80;\n\nlet message = null;\n\nif (weekly_total >= limit) {\n  message = `🚨 Budget Alert!\\n\\nYou've spent ${weekly_total} AED on Food & Groceries this week.\\nYou've hit your weekly limit of ${limit} AED!`;\n} else if (weekly_total >= pre_alert) {\n  message = `⚠️ Heads up!\\n\\nYou've spent ${weekly_total} AED on Food & Groceries this week.\\nApproaching your weekly limit of ${limit} AED!`;\n}\n\nreturn [{ json: { message, weekly_total, should_alert: message !== null } }];"
      },

      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst now = new Date();\nconst monthName = now.toLocaleString('default', { month: 'long' });\nconst year = now.getFullYear();\n\nlet message = `📊 ${monthName} ${year} Summary\\n\\n`;\nlet total = 0;\n\nfor (const row of rows) {\n  const amount = parseFloat(row.json.total) || 0;\n  total += amount;\n  message += `${row.json.category}: ${amount.toFixed(2)} AED\\n`;\n}\n\nmessage += `\\nTotal: ${total.toFixed(2)} AED`;\n\nreturn [{ json: { message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        576,
        -160

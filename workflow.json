      "parameters": {
        "jsCode": "const message = $input.item.json.message.text;\nconst parts = message.split(' ');\nconst amount = parseFloat(parts[0]);\nconst description = parts.slice(1).join(' ') || '';\nconst chat_id = $input.item.json.message.chat.id;\n\nreturn [{ json: { amount, description, chat_id } }];"
      },

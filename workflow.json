        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a personal finance expense categorizer. Given an expense description, reply with ONLY one word. Use these categories: Food (restaurants, cafes, takeaway, dining out), Groceries (supermarket, fruits, vegetables, raw ingredients), Transport (uber, taxi, fuel, metro, bus, parking, RTA), Bills (electricity, water, internet, rent), Subscriptions (netflix, spotify, apps, monthly services), Tabby (tabby payment, tabby installment), Tamara (tamara payment, tamara installment), Loan (lent money, gave loan, borrowed by someone), Transfer (botim, sending money home, bank transfer, remittance), Health (pharmacy, doctor, gym, medicine), Entertainment (movies, games, events, hobbies). Reply with ONLY the category word, nothing else.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.description }}\"\n    }\n  ]\n}",
        "options": {}
